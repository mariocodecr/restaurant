# =============================================================================
# Restaurant ERP — Environment variables template
# =============================================================================
# Copy this file to .env.local (NEVER commit .env.local — it's gitignored)
# and fill in the values for your Supabase project.
# Get them from: https://supabase.com/dashboard/project/<your-project>/settings/api

# ---- Web app (Next.js, public — exposed to the browser) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# ---- API (NestJS, server-only — NEVER exposed) ----
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE
SUPABASE_JWT_SECRET=YOUR_JWT_SECRET_HERE

# API server port
API_PORT=3001

# Web origin allowed by API CORS
WEB_ORIGIN=http://localhost:3000

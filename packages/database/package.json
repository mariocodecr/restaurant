{
  "name": "@restaurant/database",
  "version": "0.1.0",
  "description": "Supabase types, SQL migrations and seed scripts",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "clean": "rm -rf dist",
    "gen:types": "supabase gen types typescript --linked > src/types.ts",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.46.0"
  },
  "devDependencies": {
    "supabase": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
